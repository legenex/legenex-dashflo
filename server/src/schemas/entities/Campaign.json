{
  "name": "Campaign",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Campaign display name"
    },
    "vertical": {
      "type": "string",
      "description": "Vertical code this campaign belongs to"
    },
    "send_mode": {
      "type": "string",
      "enum": [
        "ping_post",
        "direct_post"
      ],
      "default": "direct_post",
      "description": "How sources send leads into this campaign: Ping Post or Direct Post"
    },
    "supplier_ids": {
      "type": "string",
      "description": "JSON array of Supplier record ids assigned to this campaign"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "name"
  ]
}