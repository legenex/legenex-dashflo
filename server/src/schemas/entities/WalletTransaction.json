{
  "name": "WalletTransaction",
  "type": "object",
  "properties": {
    "buyer_id": {
      "type": "string",
      "description": "Reference to Buyer record"
    },
    "type": {
      "type": "string",
      "enum": [
        "credit",
        "debit",
        "recharge",
        "adjustment"
      ],
      "default": "credit"
    },
    "amount": {
      "type": "number"
    },
    "balance_after": {
      "type": "number"
    },
    "description": {
      "type": "string"
    }
  },
  "required": [
    "buyer_id",
    "type",
    "amount"
  ]
}