{
  "name": "AdSpend",
  "type": "object",
  "properties": {
    "platform": {
      "type": "string",
      "default": "meta"
    },
    "mapping_id": {
      "type": "string",
      "description": "Reference to AdSpendMapping"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Spend date"
    },
    "ad_account_id": {
      "type": "string"
    },
    "level": {
      "type": "string",
      "enum": [
        "account",
        "campaign",
        "ad"
      ],
      "default": "account"
    },
    "meta_campaign_id": {
      "type": "string"
    },
    "meta_campaign_name": {
      "type": "string"
    },
    "adset_id": {
      "type": "string"
    },
    "adset_name": {
      "type": "string"
    },
    "ad_id": {
      "type": "string"
    },
    "ad_name": {
      "type": "string"
    },
    "supplier_key": {
      "type": "string",
      "description": "lowercased trimmed supplier_name, used to join spend to leads case-insensitively"
    },
    "spend": {
      "type": "number",
      "default": 0
    },
    "impressions": {
      "type": "number",
      "default": 0
    },
    "clicks": {
      "type": "number",
      "default": 0
    },
    "leads": {
      "type": "number",
      "default": 0
    },
    "video_3s_views": {
      "type": "number",
      "default": 0,
      "description": "Meta video_play_actions (3 second views). Ad level only. Thumbstop rate is this divided by impressions."
    },
    "video_thruplays": {
      "type": "number",
      "default": 0,
      "description": "Meta video_thruplay_watched_actions. Ad level only. Hold rate is this divided by impressions."
    },
    "vertical": {
      "type": "string"
    },
    "brand": {
      "type": "string"
    },
    "supplier_name": {
      "type": "string"
    },
    "cost_source": {
      "type": "string"
    }
  },
  "required": [
    "date",
    "spend"
  ]
}