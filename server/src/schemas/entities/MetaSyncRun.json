{
  "name": "MetaSyncRun",
  "type": "object",
  "properties": {
    "platform": {
      "type": "string",
      "enum": [
        "meta"
      ],
      "default": "meta"
    },
    "connection_id": {
      "type": "string"
    },
    "supplier_ad_account_id": {
      "type": "string",
      "description": "Reference to the SupplierAdAccount this run synced."
    },
    "supplier_id": {
      "type": "string"
    },
    "supplier_name": {
      "type": "string"
    },
    "ad_account_id": {
      "type": "string"
    },
    "ad_account_name": {
      "type": "string"
    },
    "currency": {
      "type": "string"
    },
    "trigger": {
      "type": "string",
      "enum": [
        "manual",
        "scheduled",
        "initial"
      ],
      "default": "manual",
      "description": "What started the run."
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "error",
        "partial"
      ],
      "description": "success = account synced cleanly. error = account failed. partial = account level ok but campaign/ad level had issues."
    },
    "account_rows": {
      "type": "number",
      "default": 0,
      "description": "Account-level daily spend rows written."
    },
    "campaign_rows": {
      "type": "number",
      "default": 0
    },
    "ad_rows": {
      "type": "number",
      "default": 0
    },
    "spend_days": {
      "type": "number",
      "default": 0,
      "description": "Number of days covered by this run's account-level window."
    },
    "spend_total": {
      "type": "number",
      "default": 0,
      "description": "Sum of account-level spend imported in this run's window, in the account currency."
    },
    "error_message": {
      "type": "string",
      "description": "Populated when status is error or partial."
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_ms": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "ad_account_id",
    "status"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}