# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Public URL the app is reachable at (used in emails, file URLs). Set in prod.
PUBLIC_BASE_URL=

# Absolute/relative path to the built frontend. Defaults to ../client/dist.
# CLIENT_DIST=
# UPLOAD_DIR=./uploads

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Either a single DATABASE_URL...
# DATABASE_URL=postgres://user:pass@localhost:5432/dashos
# ...or discrete vars:
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=dashos
PGSSL=false

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# ── LLM provider (AI Analyst, DataBot, insights) ─────────────────────────────
# LLM_PROVIDER = anthropic | openai
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Email (password reset / OTP / notifications) ─────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DashOS <no-reply@localhost>

# ── Third-party integrations (fill in as needed) ─────────────────────────────
LEADBYTE_API_KEY=
LEADBYTE_BASE_URL=
HLR_API_KEY=
HLR_BASE_URL=
TRUSTEDFORM_API_KEY=
META_ACCESS_TOKEN=
MERCURY_API_KEY=
STRIPE_API_KEY=
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_ACCESS_TOKEN=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── Admin seed (optional; used by npm run seed:admin) ────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=
